<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_accent }}">
    {{ content_for_header }}
    {{ 'figma-fonts.css' | asset_url | stylesheet_tag }}
    {{ 'figma-poster.css' | asset_url | stylesheet_tag }}
    {{ 'poster-theme.css' | asset_url | stylesheet_tag }}
    {{ 'header-adaptive.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'poster-theme.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'header-adaptive.js' | asset_url }}" defer="defer"></script>
  </head>
  <body class="store-root template-{{ request.page_type | handle }}">
    {% sections 'header-group' %}
    <main id="MainContent" role="main">{{ content_for_layout }}</main>
    {% sections 'footer-group' %}
  </body>
</html>
