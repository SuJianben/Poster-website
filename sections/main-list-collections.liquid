<section class="generic-page"><div class="page-width"><h1 class="display" style="font-size:clamp(44px,6vw,76px)">{{ 'collections.title' | t }}</h1><div class="product-grid">{% for collection in collections %}<a href="{{ collection.url }}"><div class="poster-card__image">{% if collection.featured_image %}{{ collection.featured_image | image_url: width: 700 | image_tag: alt: collection.title }}{% endif %}</div><h2 class="display" style="font-size:26px">{{ collection.title }}</h2></a>{% endfor %}</div></div></section>
{% schema %}{"name":"Collection list","settings":[]}{% endschema %}
