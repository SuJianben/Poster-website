<section class="generic-page cart-page"><div class="page-width"><h1 class="display" style="font-size:56px">{{ 'cart.title' | t }}</h1>{% if cart.item_count > 0 %}{% form 'cart', cart %}<table><tbody>{% for item in cart.items %}<tr><td>{% if item.image %}{{ item.image | image_url: width: 140 | image_tag: alt: item.product.title }}{% endif %}</td><td><a href="{{ item.url }}">{{ item.product.title }}</a></td><td><input type="number" name="updates[]" value="{{ item.quantity }}" min="0"></td><td>{{ item.final_line_price | money }}</td></tr>{% endfor %}</tbody></table><p class="price" style="margin-top:28px">{{ 'cart.total' | t }} {{ cart.total_price | money }}</p><button class="button" name="checkout" type="submit">{{ 'cart.checkout' | t }}</button>{% endform %}{% else %}<p>{{ 'cart.empty' | t }}</p><a class="button" href="{{ routes.all_products_collection_url }}">{{ 'cart.continue' | t }}</a>{% endif %}</div></section>
{% schema %}{"name":"Main cart","settings":[]}{% endschema %}
