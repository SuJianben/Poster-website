{{ 'collection-showcase.css' | asset_url | stylesheet_tag }}
{% liquid
  assign story_images = 'figma-poster-n1.jpg,figma-poster-s2.jpg,figma-poster-c3.jpg,figma-poster-r4.jpg,figma-poster-t5.jpg' | split: ','
  assign story_titles = 'Nordic Calm,Studio Colour,Cinematic Nights,Modern Rituals,Travel Notes' | split: ','
  assign story_blocks = section.blocks | where: 'type', 'story'
  assign faq_blocks = section.blocks | where: 'type', 'faq'
  assign filter_labels = section.settings.filter_labels | split: ','
  assign fallback_images = 'figma-poster-a1.jpg,figma-poster-a2.jpg,figma-poster-a3.jpg,figma-poster-a4.jpg,figma-poster-a5.jpg,figma-poster-c1.jpg,figma-poster-c2.jpg,figma-poster-c3.jpg,figma-poster-c4.jpg,figma-poster-c5.jpg,figma-poster-n1.jpg,figma-poster-n2.jpg' | split: ','
  assign fallback_titles = 'Paper Bird,Midnight Transit,Wild Bloom,Fuji Street,Bicycle Stories,The Tramp,Silver Screen,Neon Marquee,Monster Nights,City Motion,Fjord Blue,Still Water' | split: ','
  assign fallback_artists = 'Fons Heijnsbroek,Alex Mclean,Anika Reed,Aiko Tanaka,Marcel Kent,Smithsonian,Luthfian Alfajr,Christian Lue,Lilian Do Khac,Kaito Mori,Hendrik Schuette,Joakim Nådell' | split: ','
  assign fallback_prices = '$199,$149,$189,$189,$175,$249,$189,$179,$159,$179,$199,$179' | split: ','
%}
<section class="collection-showcase" data-collection-showcase>
  <header class="collection-showcase__intro page-width">
    <nav class="collection-showcase__breadcrumb" aria-label="Breadcrumb"><a href="{{ routes.root_url }}">Home</a><span aria-hidden="true">/</span><span>{{ collection.title }}</span></nav>
    <h1 class="display">{{ collection.title }}</h1><div class="collection-showcase__lede rte">{{ section.settings.intro }}</div>
  </header>
  <div class="collection-showcase__stories page-width" aria-label="Collection stories">
    {% if story_blocks.size > 0 %}{% for block in story_blocks limit: 5 %}<a class="collection-story" href="{{ block.settings.link | default: collection.url }}" {{ block.shopify_attributes }}>{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 960 | image_tag: loading: 'lazy', widths: '320,480,640,960', alt: block.settings.title }}{% else %}<img src="{{ story_images[forloop.index0] | asset_url }}" loading="lazy" alt="{{ block.settings.title | escape }}">{% endif %}<span>{{ block.settings.title }}</span></a>{% endfor %}{% else %}{% for story_title in story_titles %}<a class="collection-story" href="{{ collection.url }}"><img src="{{ story_images[forloop.index0] | asset_url }}" loading="lazy" alt="{{ story_title | escape }}"><span>{{ story_title }}</span></a>{% endfor %}{% endif %}
  </div>
  <div class="collection-showcase__catalog page-width" id="collection-products">
    <aside class="collection-showcase__filters" aria-label="Collection filters"><p class="collection-showcase__filters-title">Refine</p>{% for filter_label in filter_labels %}<details class="collection-filter"><summary>{{ filter_label | strip }}</summary><ul><li>Explore all</li><li>Featured</li><li>New arrivals</li></ul></details>{% endfor %}</aside>
    <div class="collection-showcase__results"><div class="collection-showcase__toolbar"><p>{{ fallback_titles.size }} pieces</p><button type="button" aria-label="Sort products">Sort by: Relevance <span aria-hidden="true">⌄</span></button></div><div class="collection-showcase__grid">{% for fallback_title in fallback_titles %}<article class="poster-card collection-fallback-card"><a class="poster-card__image" href="#collection-products"><img src="{{ fallback_images[forloop.index0] | asset_url }}" loading="lazy" alt="{{ fallback_title | escape }}"></a><div class="poster-card__details"><p>By: {{ fallback_artists[forloop.index0] }}</p><a href="#collection-products">{{ fallback_title }}</a><p>Starting at {{ fallback_prices[forloop.index0] }}</p></div></article>{% endfor %}</div></div>
  </div>
  {% if section.settings.show_description or faq_blocks.size > 0 %}<div class="collection-showcase__afterword page-width"><div class="collection-showcase__description rte">{% if collection.description != blank %}{{ collection.description }}{% else %}{{ section.settings.editorial_fallback }}{% endif %}</div>{% if faq_blocks.size > 0 %}<div class="collection-showcase__faq"><p class="eyebrow">Frequently asked questions</p>{% for block in faq_blocks %}<details {{ block.shopify_attributes }}><summary>{{ block.settings.question }}</summary><div class="rte">{{ block.settings.answer }}</div></details>{% endfor %}</div>{% endif %}</div>{% endif %}
</section>
{% schema %}
{"name":"Collection showcase","settings":[{"type":"richtext","id":"intro","label":"Introduction","default":"<p>Discover art and objects from independent artists, all in one place.</p>"},{"type":"text","id":"filter_labels","label":"Filter labels","default":"Product Type,Subject,Color,Art Medium,Style,Pattern"},{"type":"checkbox","id":"use_fallback","label":"Use fallback product cards","default":true},{"type":"range","id":"products_per_page","label":"Products per page","min":4,"max":24,"step":4,"default":12},{"type":"checkbox","id":"show_description","label":"Show collection description","default":true},{"type":"richtext","id":"editorial_fallback","label":"Description fallback","default":"<p>Explore distinct points of view, selected to make a room feel personal and complete.</p>"}],"blocks":[{"type":"story","name":"Aesthetic story","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"title","label":"Title","default":"New aesthetic"},{"type":"url","id":"link","label":"Collection link"}]},{"type":"faq","name":"FAQ","settings":[{"type":"text","id":"question","label":"Question","default":"What makes this collection special?"},{"type":"richtext","id":"answer","label":"Answer","default":"<p>Every piece is selected to work beautifully together while leaving room for your own point of view.</p>"}]}],"max_blocks":12}
{% endschema %}
