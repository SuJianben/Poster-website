{{ 'collection-showcase.css' | asset_url | stylesheet_tag }}

{% liquid
  assign fallback_images = 'figma-poster-n1.jpg,figma-poster-s2.jpg,figma-poster-c3.jpg,figma-poster-r4.jpg,figma-poster-t5.jpg' | split: ','
  assign fallback_titles = 'Nordic Calm,Studio Colour,Cinematic Nights,Modern Rituals,Travel Notes' | split: ','
  assign fallback_descriptions = 'Quiet landscapes and generous negative space.,Graphic colour for a more expressive room.,Film stills and after-dark atmosphere.,A gathered mix of artful daily details.,Places to keep close to home.' | split: ','
  assign story_blocks = section.blocks | where: 'type', 'story'
  assign faq_blocks = section.blocks | where: 'type', 'faq'
%}

<section class="collection-showcase" data-collection-showcase>
  <div class="collection-showcase__intro page-width">
    <nav class="collection-showcase__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a><span aria-hidden="true">/</span><span>{{ collection.title }}</span>
    </nav>
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="display">{{ collection.title }}</h1>
    <div class="collection-showcase__lede rte">{{ section.settings.intro }}</div>
  </div>

  <div class="collection-showcase__stories page-width">
    <div class="collection-showcase__section-heading">
      <p class="eyebrow">{{ section.settings.stories_eyebrow }}</p>
      <h2 class="display">{{ section.settings.stories_heading }}</h2>
    </div>
    <div class="collection-showcase__story-rail" role="list">
      {% if story_blocks.size > 0 %}
        {% for block in story_blocks %}
          <article class="collection-story" {{ block.shopify_attributes }} role="listitem">
            <a class="collection-story__link" href="{{ block.settings.link | default: collection.url }}">
              <div class="collection-story__media">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 960 | image_tag: loading: 'lazy', widths: '360,540,720,960', alt: block.settings.title }}
                {% else %}
                  {{ fallback_images[forloop.index0] | asset_url | image_tag: loading: 'lazy', alt: block.settings.title }}
                {% endif %}
              </div>
              <div class="collection-story__copy"><h3>{{ block.settings.title }}</h3><p>{{ block.settings.description }}</p><span>Explore <span aria-hidden="true">→</span></span></div>
            </a>
          </article>
        {% endfor %}
      {% else %}
        {% for fallback_title in fallback_titles %}
          <article class="collection-story" role="listitem">
            <a class="collection-story__link" href="{{ collection.url }}">
              <div class="collection-story__media">{{ fallback_images[forloop.index0] | asset_url | image_tag: loading: 'lazy', alt: fallback_title }}</div>
              <div class="collection-story__copy"><h3>{{ fallback_title }}</h3><p>{{ fallback_descriptions[forloop.index0] }}</p><span>Explore <span aria-hidden="true">→</span></span></div>
            </a>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  {% if section.settings.show_description or faq_blocks.size > 0 %}
    <div class="collection-showcase__editorial page-width">
      <div class="collection-showcase__editorial-copy rte">
        {% if collection.description != blank %}{{ collection.description }}{% else %}<p>{{ section.settings.editorial_fallback }}</p>{% endif %}
      </div>
      {% if faq_blocks.size > 0 %}
        <div class="collection-showcase__faq">
          <p class="eyebrow">Frequently asked questions</p>
          {% for block in faq_blocks %}
            <details {{ block.shopify_attributes }}><summary>{{ block.settings.question }}</summary><div class="rte">{{ block.settings.answer }}</div></details>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endif %}

  <div class="collection-showcase__products page-width" id="collection-products">
    <div class="collection-showcase__products-heading"><div><p class="eyebrow">{{ section.settings.products_eyebrow }}</p><h2 class="display">{{ section.settings.products_heading }}</h2></div><p>{{ collection.products_count }} pieces</p></div>
    {% paginate collection.products by section.settings.products_per_page %}
      <div class="collection-showcase__grid">
        {% for product in collection.products %}{% render 'poster-card', product: product %}{% else %}<p class="collection-showcase__empty">{{ 'general.no_products' | t }}</p>{% endfor %}
      </div>
      {% if paginate.pages > 1 %}<div class="collection-showcase__pagination">{{ paginate | default_pagination }}</div>{% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Collection showcase",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated collection" },
    { "type": "richtext", "id": "intro", "label": "Introduction", "default": "<p>A considered collection of art and objects made to live together.</p>" },
    { "type": "text", "id": "stories_eyebrow", "label": "Stories eyebrow", "default": "Browse the series" },
    { "type": "text", "id": "stories_heading", "label": "Stories heading", "default": "Shop by aesthetic" },
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "richtext", "id": "editorial_fallback", "label": "Editorial fallback", "default": "<p>Each story is built around a distinct point of view. Browse the pieces together, then make the collection your own.</p>" },
    { "type": "text", "id": "products_eyebrow", "label": "Products eyebrow", "default": "Curated for you" },
    { "type": "text", "id": "products_heading", "label": "Products heading", "default": "Best sellers" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 4, "max": 24, "step": 4, "default": 12 }
  ],
  "blocks": [
    { "type": "story", "name": "Aesthetic story", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "title", "label": "Title", "default": "New aesthetic" },
      { "type": "textarea", "id": "description", "label": "Description", "default": "A short description of this point of view." },
      { "type": "url", "id": "link", "label": "Collection link" }
    ] },
    { "type": "faq", "name": "FAQ", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "What makes this collection special?" },
      { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Every piece is selected to work beautifully together while leaving room for your own point of view.</p>" }
    ] }
  ],
  "max_blocks": 12
}
{% endschema %}
