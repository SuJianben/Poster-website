{{ 'collection-showcase.css' | asset_url | stylesheet_tag }}
{{ 'collection-showcase-interactions.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collection-showcase.js' | asset_url }}" defer="defer"></script>
{% liquid
  assign story_images = 'figma-poster-n1.jpg,figma-poster-s2.jpg,figma-poster-c3.jpg,figma-poster-r4.jpg,figma-poster-t5.jpg' | split: ','
  assign story_titles = 'Nordic Calm,Studio Colour,Cinematic Nights,Modern Rituals,Travel Notes' | split: ','
  assign story_blocks = section.blocks | where: 'type', 'story'
  assign faq_blocks = section.blocks | where: 'type', 'faq'
  assign filter_labels = section.settings.filter_labels | split: ','
  assign fallback_images = 'figma-poster-a1.jpg,figma-poster-a2.jpg,figma-poster-a3.jpg,figma-poster-a4.jpg,figma-poster-a5.jpg,figma-poster-c1.jpg,figma-poster-c2.jpg,figma-poster-c3.jpg,figma-poster-c4.jpg,figma-poster-c5.jpg,figma-poster-n1.jpg,figma-poster-n2.jpg' | split: ','
  assign fallback_titles = 'Paper Bird,Midnight Transit,Wild Bloom,Fuji Street,Bicycle Stories,The Tramp,Silver Screen,Neon Marquee,Monster Nights,City Motion,Fjord Blue,Still Water' | split: ','
  assign fallback_artists = 'Fons Heijnsbroek,Alex Mclean,Anika Reed,Aiko Tanaka,Marcel Kent,Smithsonian,Luthfian Alfajr,Christian Lue,Lilian Do Khac,Kaito Mori,Hendrik Schuette,Joakim Nådell' | split: ','
  assign fallback_prices = '$199,$149,$189,$189,$175,$249,$189,$179,$159,$179,$199,$179' | split: ','
  assign fallback_types = 'Art Print,Art Print,Poster,Poster,Art Print,Poster,Art Print,Art Print,Poster,Poster,Art Print,Art Print' | split: ','
  assign fallback_subjects = 'Abstract,City,Flowers,Landscape,City,People,Film,City,Film,City,Landscape,Nature' | split: ','
  assign fallback_colors = 'Cream,Blue,Yellow,Blue,Orange,Yellow,Red,Purple,Black,Blue,Blue,Blue' | split: ','
  assign fallback_mediums = 'Painting,Photography,Illustration,Photography,Photography,Photography,Photography,Photography,Photography,Photography,Photography,Photography' | split: ','
  assign fallback_styles = 'Modern,Modern,Abstract,Minimalism,Modern,Vintage,Vintage,Retro,Vintage,Modern,Minimalism,Minimalism' | split: ','
  assign fallback_patterns = 'Abstract,Solid,Floral,Solid,Solid,Vintage,Collage,Solid,Collage,Solid,Solid,Solid' | split: ','
  assign fallback_type_options = 'Art Print,Poster' | split: ','
  assign fallback_subject_options = 'Nature,Abstract,Flowers,Landscape,City,People,Film' | split: ','
  assign fallback_color_options = 'Cream,Blue,Yellow,Orange,Red,Purple,Black' | split: ','
  assign fallback_medium_options = 'Graphic Design,Painting,Illustration,Photography' | split: ','
  assign fallback_style_options = 'Vintage,Abstract,Retro,Modern,Minimalism' | split: ','
  assign fallback_pattern_options = 'Floral,Abstract,Collage,Solid,Vintage' | split: ','
%}
<section class="collection-showcase" data-collection-showcase>
  <header class="collection-showcase__intro page-width">
    <nav class="collection-showcase__breadcrumb" aria-label="Breadcrumb"><a href="{{ routes.root_url }}">Home</a><span aria-hidden="true">/</span><span>{{ collection.title }}</span></nav>
    <h1 class="display">{{ collection.title }}</h1><div class="collection-showcase__lede rte">{{ section.settings.intro }}</div>
  </header>
  <div class="collection-showcase__stories page-width" aria-label="Collection stories">
    {% if story_blocks.size > 0 %}{% for block in story_blocks limit: 5 %}<a class="collection-story" href="{{ block.settings.link | default: collection.url }}" {{ block.shopify_attributes }}>{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 960 | image_tag: loading: 'lazy', widths: '320,480,640,960', alt: block.settings.title }}{% else %}<img src="{{ story_images[forloop.index0] | asset_url }}" width="900" height="900" loading="lazy" alt="{{ block.settings.title | escape }}">{% endif %}<span>{{ block.settings.title }}</span></a>{% endfor %}{% else %}{% for story_title in story_titles %}<a class="collection-story" href="{{ collection.url }}"><img src="{{ story_images[forloop.index0] | asset_url }}" width="900" height="900" loading="lazy" alt="{{ story_title | escape }}"><span>{{ story_title }}</span></a>{% endfor %}{% endif %}
  </div>
  <div class="collection-showcase__catalog page-width" id="collection-products">
    <aside class="collection-showcase__filters" aria-label="Collection filters">
      <p class="collection-showcase__filters-title">Refine</p>
      <details class="collection-filter" open><summary>Product Type</summary><ul>{% for value in fallback_type_options %}<li><label><input type="checkbox" value="{{ value }}" data-filter-key="type" data-collection-filter> <span>{{ value }}</span></label></li>{% endfor %}</ul></details>
      <details class="collection-filter"><summary>Subject</summary><ul>{% for value in fallback_subject_options %}<li><label><input type="checkbox" value="{{ value }}" data-filter-key="subject" data-collection-filter> <span>{{ value }}</span></label></li>{% endfor %}</ul></details>
      <details class="collection-filter"><summary>Color</summary><ul>{% for value in fallback_color_options %}<li><label><input type="checkbox" value="{{ value }}" data-filter-key="color" data-collection-filter> <span>{{ value }}</span></label></li>{% endfor %}</ul></details>
      <details class="collection-filter"><summary>Art Medium</summary><ul>{% for value in fallback_medium_options %}<li><label><input type="checkbox" value="{{ value }}" data-filter-key="medium" data-collection-filter> <span>{{ value }}</span></label></li>{% endfor %}</ul></details>
      <details class="collection-filter"><summary>Style</summary><ul>{% for value in fallback_style_options %}<li><label><input type="checkbox" value="{{ value }}" data-filter-key="style" data-collection-filter> <span>{{ value }}</span></label></li>{% endfor %}</ul></details>
      <details class="collection-filter"><summary>Pattern</summary><ul>{% for value in fallback_pattern_options %}<li><label><input type="checkbox" value="{{ value }}" data-filter-key="pattern" data-collection-filter> <span>{{ value }}</span></label></li>{% endfor %}</ul></details>
      <button class="collection-showcase__clear" type="button" data-collection-clear hidden>Clear filters</button>
    </aside>
    <div class="collection-showcase__results"><div class="collection-showcase__toolbar"><p data-collection-count>{{ fallback_titles.size }} pieces</p><label class="visually-hidden" for="collection-sort-{{ section.id }}">Sort products</label><select id="collection-sort-{{ section.id }}" data-collection-sort><option value="relevance">Sort by: Relevance</option><option value="title-asc">Title: A–Z</option><option value="title-desc">Title: Z–A</option><option value="price-asc">Price: Low to high</option><option value="price-desc">Price: High to low</option></select></div><div class="collection-showcase__grid" data-collection-grid>{% for fallback_title in fallback_titles %}<article class="poster-card collection-fallback-card" data-collection-card data-title="{{ fallback_title | escape }}" data-price="{{ fallback_prices[forloop.index0] | remove: '$' }}" data-type="{{ fallback_types[forloop.index0] }}" data-subject="{{ fallback_subjects[forloop.index0] }}" data-color="{{ fallback_colors[forloop.index0] }}" data-medium="{{ fallback_mediums[forloop.index0] }}" data-style="{{ fallback_styles[forloop.index0] }}" data-pattern="{{ fallback_patterns[forloop.index0] }}"><a class="poster-card__image" href="#collection-products"><img src="{{ fallback_images[forloop.index0] | asset_url }}" width="900" height="900" loading="lazy" alt="{{ fallback_title | escape }}"></a><div class="poster-card__details"><p>By: {{ fallback_artists[forloop.index0] }}</p><a href="#collection-products">{{ fallback_title }}</a><p>Starting at {{ fallback_prices[forloop.index0] }}</p></div></article>{% endfor %}</div><p class="collection-showcase__empty" data-collection-empty hidden>No posters match these filters.</p></div>
  </div>
  {% if section.settings.show_description or faq_blocks.size > 0 %}<div class="collection-showcase__afterword page-width"><div class="collection-showcase__description rte">{% if collection.description != blank %}{{ collection.description }}{% else %}{{ section.settings.editorial_fallback }}{% endif %}</div>{% if faq_blocks.size > 0 %}<div class="collection-showcase__faq"><p class="eyebrow">Frequently asked questions</p>{% for block in faq_blocks %}<details {{ block.shopify_attributes }}><summary>{{ block.settings.question }}</summary><div class="rte">{{ block.settings.answer }}</div></details>{% endfor %}</div>{% endif %}</div>{% endif %}
</section>
{% schema %}
{"name":"Collection showcase","settings":[{"type":"richtext","id":"intro","label":"Introduction","default":"<p>Discover art and objects from independent artists, all in one place.</p>"},{"type":"text","id":"filter_labels","label":"Filter labels","default":"Product Type,Subject,Color,Art Medium,Style,Pattern"},{"type":"checkbox","id":"use_fallback","label":"Use fallback product cards","default":true},{"type":"range","id":"products_per_page","label":"Products per page","min":4,"max":24,"step":4,"default":12},{"type":"checkbox","id":"show_description","label":"Show collection description","default":true},{"type":"richtext","id":"editorial_fallback","label":"Description fallback","default":"<p>Explore distinct points of view, selected to make a room feel personal and complete.</p>"}],"blocks":[{"type":"story","name":"Aesthetic story","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"title","label":"Title","default":"New aesthetic"},{"type":"url","id":"link","label":"Collection link"}]},{"type":"faq","name":"FAQ","settings":[{"type":"text","id":"question","label":"Question","default":"What makes this collection special?"},{"type":"richtext","id":"answer","label":"Answer","default":"<p>Every piece is selected to work beautifully together while leaving room for your own point of view.</p>"}]}],"max_blocks":12}
{% endschema %}
