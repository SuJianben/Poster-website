<section class="section"><div class="page-width"><div class="section-heading"><span class="eyebrow">{{ section.settings.eyebrow }}</span>{% if section.settings.link_label != blank %}<a class="text-link" href="{{ section.settings.link }}">{{ section.settings.link_label }} →</a>{% endif %}</div><div class="category-rail">{% for block in section.blocks %}<a class="category" href="{{ block.settings.link }}" {{ block.shopify_attributes }}><div class="category__image">{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.title }}{% else %}{{ 'collection-1' | placeholder_svg_tag }}{% endif %}</div><span>{{ block.settings.title }}</span></a>{% endfor %}</div></div></section>
{% schema %}{"name":"Category rail","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Shop by category"},{"type":"text","id":"link_label","label":"Link label","default":"View all"},{"type":"url","id":"link","label":"Link"}],"blocks":[{"type":"category","name":"Category","settings":[{"type":"text","id":"title","label":"Title","default":"Film"},{"type":"image_picker","id":"image","label":"Image"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Category rail","blocks":[{"type":"category","settings":{"title":"Film"}},{"type":"category","settings":{"title":"Music"}},{"type":"category","settings":{"title":"Sports"}},{"type":"category","settings":{"title":"Nordic"}}]}]}{% endschema %}
