<section class="product-page"><div class="page-width product-layout"><div class="product-media">{% if product.featured_media %}{{ product.featured_media | image_url: width: 1400 | image_tag: widths: '600,900,1400', alt: product.title }}{% endif %}</div><div class="product-info"><span class="eyebrow">{{ product.vendor }}</span><h1>{{ product.title }}</h1><p class="price">{{ product.selected_or_first_available_variant.price | money }}</p>{% if product.description != blank %}<div>{{ product.description }}</div>{% endif %}{% form 'product', product, class: 'product-form' %}{% unless product.has_only_default_variant %}<label for="Variant-{{ section.id }}">{{ 'product.variant' | t }}</label><select name="id" id="Variant-{{ section.id }}">{% for variant in product.variants %}<option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>{{ variant.title }} — {{ variant.price | money }}</option>{% endfor %}</select>{% endunless %}<label for="Quantity-{{ section.id }}">{{ 'product.quantity' | t }}</label><input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1"><button class="button" type="submit" {% unless product.available %}disabled{% endunless %}>{% if product.available %}{{ 'product.add_to_cart' | t }}{% else %}{{ 'product.sold_out' | t }}{% endif %}</button>{% endform %}</div></div></section>
{% schema %}{"name":"Main product","settings":[]}{% endschema %}
