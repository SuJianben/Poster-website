{{ 'content-page.css' | asset_url | stylesheet_tag }}
{{ 'contact-page.css' | asset_url | stylesheet_tag }}
<script src="{{ 'content-page.js' | asset_url }}" defer="defer"></script>

{% assign page_updated_at = page.updated_at | default: page.published_at %}

<section class="cp-page cp-contact" data-content-page>
  <div class="cp-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}" aria-label="Home">
      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2.5 7.2 8 2.8l5.5 4.4v6.1H9.9V9.7H6.1v3.6H2.5Z" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/></svg>
    </a>
    <span>/</span>
    <span aria-current="page">{{ page.title }}</span>
  </div>

  <article class="cp-card">
    <header class="cp-card__header">
      <div>
        <h1>{{ page.title }}</h1>
        {% if page_updated_at != blank %}
          <p class="cp-updated">
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m10.8 2.4 2.8 2.8M3.1 12.9l1.1-3.5 6.6-6.6 2.8 2.8-6.6 6.6Z" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Last updated on {{ page_updated_at | date: '%B %-d, %Y at %-I:%M %p' }}
          </p>
        {% endif %}
      </div>
      <div class="cp-actions" aria-label="Page actions">
        <button type="button" data-cp-print aria-label="Print page">
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4.5 5V1.9h7V5M4 11.5H2.5V6.2h11v5.3H12M4.5 9.7h7v4.4h-7Z" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
        </button>
        <button type="button" data-cp-copy aria-label="Copy page link">
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M5 4.2V2.5h7v9H9.7M4 5.2h6v8.3H4Z" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </header>

    <div class="cp-body cp-contact__body">
      {% if page.content != blank %}<div class="rte cp-contact__intro">{{ page.content }}</div>{% endif %}

      {% form 'contact', class: 'cp-contact__form' %}
        {% if form.posted_successfully? %}
          <p class="cp-contact__success" role="status">Thanks for getting in touch. We’ll get back to you shortly.</p>
        {% endif %}
        {{ form.errors | default_errors }}

        <div class="cp-contact__field">
          <label for="ContactFormName">Name</label>
          <input id="ContactFormName" type="text" name="contact[name]" autocomplete="name" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
        </div>
        <div class="cp-contact__field">
          <label for="ContactFormEmail">Email <span aria-hidden="true">*</span></label>
          <input id="ContactFormEmail" type="email" name="contact[email]" autocomplete="email" autocorrect="off" autocapitalize="off" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
        </div>
        <div class="cp-contact__field">
          <label for="ContactFormPhone">Phone</label>
          <input id="ContactFormPhone" type="tel" name="contact[phone]" autocomplete="tel" value="{% if form.phone %}{{ form.phone }}{% endif %}">
        </div>
        <div class="cp-contact__field">
          <label for="ContactFormMessage">Message <span aria-hidden="true">*</span></label>
          <textarea id="ContactFormMessage" name="contact[body]" rows="7" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button class="cp-contact__submit" type="submit">Send message</button>
      {% endform %}

      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'cp-contact__image', loading: 'lazy', widths: '640,900,1200,1600', alt: section.settings.image.alt | default: page.title }}
      {% else %}
        <img class="cp-contact__image" src="{{ 'figma-lifestyle-hero.jpg' | asset_url }}" width="1600" height="900" loading="lazy" alt="{{ page.title | escape }}">
      {% endif %}
    </div>
  </article>
</section>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image below form"
    }
  ]
}
{% endschema %}
