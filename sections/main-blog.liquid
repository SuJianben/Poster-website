<section class="generic-page"><div class="page-width"><span class="eyebrow">Journal</span><h1 class="display" style="font-size:clamp(44px,6vw,76px)">{{ blog.title }}</h1><div class="product-grid">{% for article in blog.articles %}<article><a class="poster-card__image" href="{{ article.url }}">{% if article.image %}{{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: article.title }}{% endif %}</a><h2 class="display" style="font-size:25px">{{ article.title }}</h2><p style="color:var(--muted)">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p></article>{% endfor %}</div></div></section>
{% schema %}{"name":"Main blog","settings":[]}{% endschema %}
