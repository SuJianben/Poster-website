<section class="generic-page"><div class="page-width" style="max-width:550px;text-align:center"><h1 class="display" style="font-size:56px">{{ shop.name }}</h1><p>{{ 'password.message' | t }}</p>{% form 'storefront_password' %}{{ form.errors | default_errors }}<input style="padding:14px;border:1px solid var(--line);width:100%" type="password" name="password" placeholder="{{ 'password.placeholder' | t }}"><button class="button" style="margin-top:12px" type="submit">{{ 'password.submit' | t }}</button>{% endform %}</div></section>
{% schema %}{"name":"Password","settings":[]}{% endschema %}
