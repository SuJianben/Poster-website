<section class="section"><div class="page-width editorial {% if section.settings.image_position == 'right' %}editorial--reverse{% endif %}"><div class="editorial__image">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', widths: '500,750,1000,1500', alt: section.settings.heading }}{% else %}{{ 'lifestyle-2' | placeholder_svg_tag }}{% endif %}</div><div class="editorial__copy"><span class="eyebrow">{{ section.settings.eyebrow }}</span><h2>{{ section.settings.heading }}</h2><p>{{ section.settings.text }}</p>{% if section.settings.link_label != blank %}<a class="text-link" href="{{ section.settings.link }}">{{ section.settings.link_label }} →</a>{% endif %}</div></div>{% if section.settings.collection != blank %}<div class="page-width product-grid">{% for product in section.settings.collection.products limit: 4 %}{% render 'poster-card', product: product %}{% endfor %}</div>{% endif %}</section>
{% schema %}{"name":"Editorial with products","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"select","id":"image_position","label":"Image position","default":"left","options":[{"value":"left","label":"Left"},{"value":"right","label":"Right"}]},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Editorial / Vol. 03"},{"type":"text","id":"heading","label":"Heading","default":"Nordic Calm."},{"type":"textarea","id":"text","label":"Text","default":"Muted palettes, clean lines, and Scandinavian wisdom—prints that make any room breathe."},{"type":"text","id":"link_label","label":"Link label","default":"Explore the series"},{"type":"url","id":"link","label":"Link"},{"type":"collection","id":"collection","label":"Products collection"}],"presets":[{"name":"Editorial with products"}]}{% endschema %}
