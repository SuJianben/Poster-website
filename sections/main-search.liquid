<section class="generic-page"><div class="page-width"><h1 class="display" style="font-size:clamp(44px,6vw,76px)">{{ 'search.title' | t }}</h1><form action="{{ routes.search_url }}" method="get"><input style="padding:14px;border:1px solid var(--line);min-width:260px" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'search.placeholder' | t }}"><button class="button" type="submit">{{ 'general.search' | t }}</button></form>{% if search.performed %}<div class="product-grid">{% for item in search.results %}{% if item.object_type == 'product' %}{% render 'poster-card', product: item %}{% endif %}{% endfor %}</div>{% endif %}</div></section>
{% schema %}{"name":"Main search","settings":[]}{% endschema %}
