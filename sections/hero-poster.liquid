<section id="top" class="hero">
  <div class="hero__media">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', widths: '750,1100,1600,2400', alt: section.settings.heading }}{% else %}<img src="{{ 'figma-lifestyle-hero.jpg' | asset_url }}" alt="{{ section.settings.heading | escape }}" width="2000" height="1333">{% endif %}</div><div class="hero__shade"></div>
  <div class="hero__content"><h1 class="rise-in">{{ section.settings.heading }}</h1>{% if section.settings.text != blank %}<p class="rise-in">{{ section.settings.text }}</p>{% endif %}{% if section.settings.button_label != blank %}<a class="button button--light rise-in" href="{{ section.settings.button_link }}">{{ section.settings.button_label }} →</a>{% endif %}</div>
  <div class="hero__scroll"><span class="nav-label">Scroll</span><span class="float-y">↓</span></div>
</section>
{% schema %}{"name":"Poster hero","settings":[{"type":"image_picker","id":"image","label":"Hero image"},{"type":"text","id":"heading","label":"Heading","default":"Posters that make walls feel like home."},{"type":"text","id":"text","label":"Text","default":"Curated art prints from around the world."},{"type":"text","id":"button_label","label":"Button label","default":"Shop all posters"},{"type":"url","id":"button_link","label":"Button link"}]}{% endschema %}
