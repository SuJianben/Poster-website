{{ 'gallery-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'gallery-hero.js' | asset_url }}" defer="defer"></script>

<section id="top" class="gallery-hero" data-gallery-hero data-section-id="{{ section.id }}" aria-roledescription="carousel" aria-label="Featured poster collections">
  <div class="gallery-hero__slides">
    {% for block in section.blocks %}
      {% liquid
        assign fallback_asset = block.settings.asset_name | default: 'figma-lifestyle-hero.jpg'
        assign slide_alt = block.settings.image.alt | default: block.settings.title
      %}
      <article class="gallery-hero__slide{% if forloop.first %} is-active{% endif %}" data-gallery-slide data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }} aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}">
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 2400 | image_tag: class: 'gallery-hero__image', loading: 'eager', widths: '750,1100,1600,2400', alt: slide_alt }}
        {% else %}
          <img class="gallery-hero__image" src="{{ fallback_asset | asset_url }}" alt="{{ slide_alt | escape }}" width="2000" height="1333"{% unless forloop.first %} loading="lazy"{% endunless %}>
        {% endif %}
      </article>
    {% else %}
      <article class="gallery-hero__slide is-active" data-gallery-slide data-index="0" aria-hidden="false"><img class="gallery-hero__image" src="{{ 'figma-lifestyle-hero.jpg' | asset_url }}" alt="Poster collection" width="2000" height="1333"></article>
    {% endfor %}
  </div>

  <div class="gallery-hero__veil" aria-hidden="true"></div>
  <div class="gallery-hero__content" data-gallery-content>
    {% for block in section.blocks %}
      <div class="gallery-hero__copy{% if forloop.first %} is-active{% endif %}" data-gallery-copy data-index="{{ forloop.index0 }}"{% unless forloop.first %} hidden{% endunless %}>
        <p class="gallery-hero__counter" data-gallery-counter>01 / 01</p>
        <h1>{{ block.settings.title }}</h1>
        {% if block.settings.text != blank %}<p class="gallery-hero__description">{{ block.settings.text }}</p>{% endif %}
        {% if block.settings.button_label != blank %}<a class="gallery-hero__link" href="{{ block.settings.button_link | default: routes.all_products_collection_url }}">{{ block.settings.button_label }} <span aria-hidden="true">→</span></a>{% endif %}
      </div>
    {% else %}
      <div class="gallery-hero__copy is-active" data-gallery-copy data-index="0"><p class="gallery-hero__counter">01 / 01</p><h1>Posters that make walls feel like home.</h1></div>
    {% endfor %}

    {% if section.blocks.size > 1 %}
      <div class="gallery-hero__controls">
        <button class="gallery-hero__button" type="button" data-gallery-previous aria-label="Previous banner"><span aria-hidden="true">←</span></button>
        <button class="gallery-hero__button" type="button" data-gallery-next aria-label="Next banner"><span aria-hidden="true">→</span></button>
      </div>
    {% endif %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="gallery-hero__thumbnails" aria-label="Choose a banner">
      {% for block in section.blocks %}
        {% liquid
          assign fallback_asset = block.settings.asset_name | default: 'figma-lifestyle-hero.jpg'
          assign thumb_alt = block.settings.image.alt | default: block.settings.title
        %}
        <button class="gallery-hero__thumbnail{% if forloop.first %} is-active{% endif %}" type="button" data-gallery-thumbnail data-index="{{ forloop.index0 }}" aria-label="Show {{ block.settings.title | escape }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '240,400,600', alt: thumb_alt }}
          {% else %}
            <img src="{{ fallback_asset | asset_url }}" alt="{{ thumb_alt | escape }}" width="360" height="180" loading="lazy">
          {% endif %}
        </button>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Gallery hero",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "slide",
      "name": "Banner slide",
      "settings": [
        {"type":"image_picker","id":"image","label":"Banner image"},
        {"type":"text","id":"asset_name","label":"Bundled image asset","default":"figma-lifestyle-hero.jpg","info":"Used when no Shopify image is selected."},
        {"type":"text","id":"title","label":"Heading","default":"Posters that make walls feel like home."},
        {"type":"textarea","id":"text","label":"Description","default":"Curated art prints from around the world."},
        {"type":"text","id":"button_label","label":"Button label","default":"Shop collection"},
        {"type":"url","id":"button_link","label":"Button link"}
      ]
    }
  ],
  "presets": [{"name":"Gallery hero","blocks":[{"type":"slide"},{"type":"slide"},{"type":"slide"}]}]
}
{% endschema %}
