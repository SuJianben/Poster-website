{{ 'featured-flow.css' | asset_url | stylesheet_tag }}
<script src="{{ 'featured-flow.js' | asset_url }}" defer="defer"></script>

{% assign tilted_titles = 'Paper Bird|Midnight Transit|Wild Bloom|Fuji Street|Bicycle Stories|Northbound|Track Lines|Lawson Glow|City Motion|Quiet Ritual' | split: '|' %}
{% assign tilted_meta = 'Fons Heijnsbroek · A2 · $199|Mira Cole · A2 · $179|Noah Fields · A2 · $169|Aiko Tanaka · A2 · $189|Riku Studio · A2 · $179|Sora Kim · A2 · $159|Yuki Ito · A2 · $169|Nami Okada · A2 · $189|Kaito Mori · A2 · $179|Hana Watanabe · A2 · $199' | split: '|' %}
{% assign tilted_assets = 'reference-tilted-01.jpg|reference-tilted-02.jpg|reference-tilted-03.jpg|reference-tilted-04.jpg|reference-tilted-05.jpg|reference-tilted-06.jpg|reference-tilted-07.jpg|reference-tilted-08.jpg|reference-tilted-09.jpg|reference-tilted-10.jpg' | split: '|' %}

<section class="tilted-carousel" data-tilted-carousel aria-label="Image carousel">
  <div class="tilted-carousel__app">
    <header class="tilted-carousel__heading">
      <p>Featured this week</p>
      <h2>Handpicked drops.</h2>
    </header>
    <div class="tilted-carousel__viewport" data-tilted-viewport>
      <div class="tilted-carousel__track" data-tilted-track>
      {% for asset_name in tilted_assets %}
        {% assign title = tilted_titles[forloop.index0] %}
        {% assign meta = tilted_meta[forloop.index0] %}
          <article class="tilted-carousel__slide" data-tilted-slide data-title="{{ title | escape }}" data-meta="{{ meta | escape }}" data-link="#" data-source="mock" aria-current="false">
            <button class="tilted-carousel__image" type="button" data-tilted-select aria-label="Show {{ title | escape }}">
              <img src="{{ asset_name | asset_url }}" alt="{{ title | escape }}" width="500" height="667"{% unless forloop.index0 == 3 %} loading="lazy"{% endunless %}>
            </button>
          </article>
      {% endfor %}
      </div>
    </div>
    <div class="tilted-carousel__product" data-tilted-product>
      <h3 data-tilted-title>{{ tilted_titles[3] }}</h3>
      <p data-tilted-meta>{{ tilted_meta[3] }}</p>
      <a class="tilted-carousel__link" data-tilted-link href="#">View poster <span aria-hidden="true">→</span></a>
    </div>
  </div>

  <div class="tilted-carousel__controls" aria-label="Carousel controls">
    <button class="tilted-carousel__arrow" type="button" data-tilted-previous aria-label="Previous image"><span aria-hidden="true">‹</span></button>
    <div class="tilted-carousel__dots" data-tilted-dots>
      {% for asset_name in tilted_assets %}
        <button type="button" class="tilted-carousel__dot" data-tilted-dot aria-label="Show image {{ forloop.index }}"></button>
      {% endfor %}
    </div>
    <button class="tilted-carousel__arrow" type="button" data-tilted-next aria-label="Next image"><span aria-hidden="true">›</span></button>
  </div>
</section>

{% schema %}
{"name":"Tilted carousel","settings":[]}
{% endschema %}
