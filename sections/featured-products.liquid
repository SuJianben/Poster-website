<section class="section section--soft"><div class="featured-title page-width"><span class="eyebrow">{{ section.settings.eyebrow }}</span><h2>{{ section.settings.heading }}</h2></div><div class="product-rail">{% if section.settings.collection != blank %}{% for product in section.settings.collection.products limit: section.settings.products_to_show %}{% render 'poster-card', product: product, featured: true %}{% endfor %}{% else %}{% for i in (1..5) %}<article class="poster-card featured-product"><div class="poster-card__image">{{ 'product-' | append: i | placeholder_svg_tag }}</div></article>{% endfor %}{% endif %}</div></section>
{% schema %}{"name":"Featured products","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Featured this week"},{"type":"text","id":"heading","label":"Heading","default":"Handpicked drops."},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_to_show","label":"Products to show","min":3,"max":12,"step":1,"default":7}]}{% endschema %}
