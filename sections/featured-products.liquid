<section class="section section--soft"><div class="featured-title page-width"><span class="eyebrow">{{ section.settings.eyebrow }}</span><h2>{{ section.settings.heading }}</h2></div><div class="product-rail">{% if section.settings.collection != blank %}{% for product in section.settings.collection.products limit: section.settings.products_to_show %}{% render 'poster-card', product: product, featured: true %}{% endfor %}{% else %}{% for block in section.blocks %}<article class="poster-card featured-product" {{ block.shopify_attributes }}><a class="poster-card__image" href="{{ block.settings.link }}"><img src="{{ block.settings.asset_name | asset_url }}" alt="{{ block.settings.title | escape }}" width="900" height="1350" loading="lazy"></a><div class="poster-card__details"><a href="{{ block.settings.link }}">{{ block.settings.title }}</a><p>{{ block.settings.meta }}</p></div></article>{% endfor %}{% endif %}</div></section>
{% schema %}{"name":"Featured products","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Featured this week"},{"type":"text","id":"heading","label":"Heading","default":"Handpicked drops."},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_to_show","label":"Products to show","min":3,"max":12,"step":1,"default":7}],"blocks":[{"type":"poster","name":"Figma poster","settings":[{"type":"text","id":"asset_name","label":"Bundled Figma asset filename"},{"type":"text","id":"title","label":"Title"},{"type":"text","id":"meta","label":"Meta"},{"type":"url","id":"link","label":"Product link"}]}],"max_blocks":12}{% endschema %}
